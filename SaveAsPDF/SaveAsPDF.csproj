  <!-- Register COM classes on every build (regasm only, no type-library export).
  <Target Name="RegisterComAddin" AfterTargets="Build">
    <Exec Command="&quot;$(FrameworkDir)$(FrameworkVersion)\RegAsm.exe&quot; /codebase &quot;$(TargetPath)&quot;" IgnoreExitCode="true" />
  </Target>-->
  <Target Name="RegisterComAddin" AfterTargets="Build">
    <!-- Register for 32-bit Outlook -->
    <Exec Command="powershell -Command &quot;Start-Process 'C:\Windows\Microsoft.NET\Framework\v4.0.30319\RegAsm.exe' -ArgumentList '/codebase \&quot;$(TargetPath)\&quot;' -Verb RunAs -Wait&quot;" IgnoreExitCode="true" />
    <!-- Register for 64-bit Outlook -->
    <Exec Command="powershell -Command &quot;Start-Process 'C:\Windows\Microsoft.NET\Framework64\v4.0.30319\RegAsm.exe' -ArgumentList '/codebase \&quot;$(TargetPath)\&quot;' -Verb RunAs -Wait&quot;" IgnoreExitCode="true" />
  </Target>
